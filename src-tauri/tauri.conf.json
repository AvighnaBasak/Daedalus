{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daedalus",
  "version": "0.1.0",
  "identifier": "dev.daedalus.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Daedalus",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "center": true,
        "resizable": true,
        "alwaysOnTop": false,
        "backgroundColor": "#0A0A0A"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' 'unsafe-eval'; worker-src 'self' blob:; connect-src 'self' ipc: https://ipc.localhost; frame-src 'self' http://localhost:* http://127.0.0.1:* http://[::1]:* https:",
      "dangerousDisableAssetCspModification": ["style-src"],
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "app",
      "dmg",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 Daedalus contributors. AGPL-3.0.",
    "category": "DeveloperTool",
    "shortDescription": "A power-user desktop cockpit for the Claude Code CLI",
    "longDescription": "Daedalus is a lightweight, non-Electron desktop shell that houses the real Claude Code CLI — a token-efficient, MCP-juiced, agentic cockpit with a matte-black editorial UI.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist",
      "dmg": {
        "windowSize": { "width": 540, "height": 380 },
        "appPosition": { "x": 140, "y": 200 },
        "applicationFolderPosition": { "x": 400, "y": 200 }
      }
    }
  }
}
